<?xml version="1.0" encoding="utf-8"?>
<Configuration>
  <Format>cobertura</Format>
  <IncludeTestAssembly>False</IncludeTestAssembly>
  <ExcludeAssembliesWithoutSources>MissingAll</ExcludeAssembliesWithoutSources>
  <DeterministicReport>True</DeterministicReport>
  <CodeCoverage>
    <ModulePaths>
      <Include>
        <ModulePath>.*ReadingLog\.Core\.dll$</ModulePath>
        <ModulePath>.*ReadingLog\.Storage\.Json\.dll$</ModulePath>
        <ModulePath>.*ReadingLog\.Api\.dll$</ModulePath>
        <ModulePath>.*ReadingLog\.Cli\.dll$</ModulePath>
      </Include>
    </ModulePaths>
    <Sources>
      <Exclude>
        <Source>.*[/\\]obj[/\\].*\.g\.cs$</Source>
      </Exclude>
    </Sources>
  </CodeCoverage>
</Configuration>
